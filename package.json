{
  "name": "speedwagon",
  "version": "0.0.2",
  "description": "A CLI tool that detects structural code duplication in JavaScript/TypeScript projects",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "bin": {
    "speedwagon": "dist/main.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "ts": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeonjuan/speedwagon.git"
  },
  "author": "YeonJuAn",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yeonjuan/speedwagon/issues"
  },
  "homepage": "https://github.com/yeonjuan/speedwagon#readme",
  "dependencies": {
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "optionator": "^0.9.4",
    "oxc-parser": "^0.123.0",
    "oxc-walker": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.0",
    "knip": "^6.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
